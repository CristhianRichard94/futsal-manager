# Postgres connection string. Locally via docker-compose: postgresql://postgres:postgres@db:5432/futsal
# In production, use the Supabase connection string.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/futsal

# Must match the NEXTAUTH_SECRET used by the frontend (NextAuth.js).
NEXTAUTH_SECRET=change-me

# Comma-separated list of allowed CORS origins.
# WARNING: never set this to "*" — the app fails to boot if ALLOWED_ORIGINS
# resolves to "*" while credentialed CORS requests are enabled (allow_credentials=True).
# Always list explicit origins, including in production.
ALLOWED_ORIGINS=http://localhost:3000

# Mercado Pago access token (Checkout Pro). Get it from your MP developer
# dashboard. Required for venues that have deposit_required enabled —
# reservation creation for those venues will fail without it.
MERCADOPAGO_ACCESS_TOKEN=

# Flat deposit amount (in the currency configured on your MP account) charged
# at booking time for venues with deposit_required enabled. Not configurable
# per-venue/per-field.
DEPOSIT_AMOUNT=1000

# Used to build the MP Checkout Pro back_urls (where the browser is
# redirected after payment).
FRONTEND_BASE_URL=http://localhost:3000

# Used to build the MP Checkout Pro notification_url (where MP POSTs
# payment webhooks). Must be publicly reachable by Mercado Pago in
# non-local environments.
BACKEND_BASE_URL=http://localhost:8000

# Shared secret used to authenticate the frontend's server-side call to
# POST /auth/sync (invoked from the NextAuth `jwt` callback right after a
# verified Google sign-in). Must match the frontend's INTERNAL_SYNC_SECRET.
# Generate with: openssl rand -base64 32
INTERNAL_SYNC_SECRET=
