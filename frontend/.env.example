# Base URL of the FastAPI backend (no trailing slash).
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# NextAuth
# Generate with: openssl rand -base64 32
# Must match the backend's NEXTAUTH_SECRET (see backend/.env / config.py) —
# the frontend mints a short-lived HS256 JWT with this secret and the
# backend verifies it with the same secret.
NEXTAUTH_SECRET=change-me
NEXTAUTH_URL=http://localhost:3000

# Google OAuth (create credentials at https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Shared secret sent as the X-Internal-Sync-Secret header on the server-side
# call to POST /auth/sync (see the NextAuth `jwt` callback in lib/authOptions.ts).
# Must match the backend's INTERNAL_SYNC_SECRET. NOT prefixed with
# NEXT_PUBLIC_ — this must never be exposed to the browser.
# Generate with: openssl rand -base64 32
INTERNAL_SYNC_SECRET=
